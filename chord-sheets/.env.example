# Comma-separated hostnames allowed for “Import from URL” (public-domain / CC publishers only).
# Leave empty to disable server fetch; users can still paste charts manually.
# Example (do not enable domains you have not vetted):
# ALLOWED_FETCH_HOSTS=www.example-pd-hymnal.org,hymnary.org

ALLOWED_FETCH_HOSTS=

# Optional (future): programmable chord search, e.g. Google Programmable Search
# GOOGLE_CSE_KEY=
# GOOGLE_CSE_CX=
